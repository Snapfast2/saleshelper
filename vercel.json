{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/crm/keep-alive",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/push/check-new-clients",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/push/check-reminders",
      "schedule": "*/15 * * * *"
    }
  ]
}
